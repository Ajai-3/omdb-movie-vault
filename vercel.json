{
  "version": 2,
  "functions": {
    "backend/src/server.ts": {
      "runtime": "vercel-node@latest"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/backend/src/server.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/frontend/index.html"
    }
  ]
}
